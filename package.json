{
  "name": "ig-iap-tunnel-action",
  "version": "1.0.0",
  "description": "GitHub Action to set up an IAP tunnel to a GCP instance group via ig-iap-tunnel",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js && esbuild src/post.ts --bundle --platform=node --target=node24 --outfile=dist/post/index.js",
    "test": "jest",
    "all": "npm run build && npm test"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
